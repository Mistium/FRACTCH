      if @Permissions_Has(perm: "javascript") {
        MistiumEval.cmdBlock(CODE: input2);
      } else {
        if input2 == "restrict" {
          MistiumEval.restrictedCmdBlock(CODE: data.itemoflist(INDEX: 3, LIST: list("Split Text")));
        } else {
          @Log_Error(Data: "eval command missing 'javascript' Permission", Type: "Permission");
        }
      }
      stop "this script";
    }
    case "log" {
      mistsutils.patchcommand(A: "const logs = target.variables[\")./tR8V[bp)bg1K2.|v(\"].value.slice(1)");
      mistsutils.patchcommand(A: "target.log(\"log\", ...logs)");
      mistsutils.patchcommand(A: "for (let i = 0; i < logs.length; i ++) { try { logs[i] = JSON.smartStringify(logs[i]) } catch { logs[i] = \"Unable to display this value\" }; logs[i] = \"Log: \" + logs[i] }");
      mistsutils.patchcommand2(A: vars["OSL // Window"], B: ".logs.push(...logs)");
      stop "this script";
    }
    case "warn" {
      mistsutils.patchcommand(A: "const logs = target.variables[\")./tR8V[bp)bg1K2.|v(\"].value.slice(1)");
      mistsutils.patchcommand(A: "target.log(\"warn\", ...logs)");
      mistsutils.patchcommand(A: "for (let i = 0; i < logs.length; i ++) { try { logs[i] = JSON.smartStringify(logs[i]) } catch { logs[i] = \"Unable to display this value\" }; logs[i] = \"Warn: \" + logs[i] }");
      mistsutils.patchcommand2(A: vars["OSL // Window"], B: ".logs.push(...logs)");
      stop "this script";
    }
    case "error" {
      mistsutils.patchcommand(A: "const logs = target.variables[\")./tR8V[bp)bg1K2.|v(\"].value.slice(1)");
      mistsutils.patchcommand(A: "target.log(\"error\", ...logs)");
      mistsutils.patchcommand(A: "for (let i = 0; i < logs.length; i ++) { try { logs[i] = JSON.smartStringify(logs[i]) } catch { logs[i] = \"Unable to display this value\" }; logs[i] = \"Error: \" + logs[i] }");
      mistsutils.patchcommand2(A: vars["OSL // Window"], B: ".logs.push(...logs)");
      stop "this script";
    }
    case "throw" {
      if input2 == "error" {
        @Log_Error(Data: data.itemoflist(INDEX: 3, LIST: list("Split Text")), Type: "Throw");
      } else {
        @Log_Error(Data: input2, Type: "Throw");
      }
      stop "this script";
    }
    case "network" {
      @OSL_Commands_Network(input2: input2);
      stop "this script";
    }
    case "sound" {
      @OSL_Commands_Sound(input2: input2);
      stop "this script";
    }
    case "http" {
      if data.itemoflist(INDEX: 2, LIST: list("Split Text")) == "newtab" {
        mistsutils.patchcommand3(A: "window.open(", B: data.itemoflist(INDEX: 3, LIST: list("Split Text")), C: ")");
      }
      stop "this script";
    }
    case "3dr" {
      @OSL_Commands_3dr(input2: input2);
      stop "this script";
    }
    case "uri" {
      @OSL_Commands_Uri(command: input2);
      stop "this script";
    }
    case "shader" {
      mistsutils.patchcommand2(A: "const id = ", B: vars["WIndow // ID"] .. ("-" .. data.itemoflist(INDEX: 3, LIST: list("Split Text"))));
      switch input2 {
        case "create" {
          mistiumshaders.newShader(ID: mistsutils.patchreporter(A: "id"), VERT: data.itemoflist(INDEX: 4, LIST: list("Split Text")), FRAG: data.itemoflist(INDEX: 5, LIST: list("Split Text")), W: data.itemoflist(INDEX: 6, LIST: list("Split Text")), H: data.itemoflist(INDEX: 7, LIST: list("Split Text")));
        }
        case "uniform" {
          mistiumshaders.setUniform(NAME: data.itemoflist(INDEX: 4, LIST: list("Split Text")), ID: mistsutils.patchreporter(A: "id"), TYPE: data.itemoflist(INDEX: 5, LIST: list("Split Text")), VAL: data.itemoflist(INDEX: 6, LIST: list("Split Text")));
        }
        case "resize" {
          mistiumshaders.resizeShader(ID: mistsutils.patchreporter(A: "id"), W: data.itemoflist(INDEX: 4, LIST: list("Split Text")), H: data.itemoflist(INDEX: 5, LIST: list("Split Text")));
        }
        case "remove" {
          mistiumshaders.deleteShader(ID: mistsutils.patchreporter(A: "id"));
        }
        case "stamp" {
          mistiumshaders.renderShader(ID: mistsutils.patchreporter(A: "id"));
          @Stamp_myself_skin_size(width: data.itemoflist(INDEX: 4, LIST: list("Split Text")), height: data.itemoflist(INDEX: 5, LIST: list("Split Text")), skin_w: 256, skin_h: 256);
        }
      }
    }
    case "save" {
      if @Permissions_Has(perm: ".sandbox") {
        stop "this script";
      }
      if data.itemoflist(INDEX: 3, LIST: list("Split Text")) == "set_directory" {
        if !operator.contains(STRING1: data.itemoflist(INDEX: 2, LIST: list("Split Text")), STRING2: "/") {
          vars["OSL// Temp4"] = mistsutils.patchreporter(A: "`${osl.user_folder}/application data/`") .. data.itemoflist(INDEX: 2, LIST: list("Split Text"));
          mistsutils.patchcommand2(A: "const val = ", B: @File_get_item(id: vars["OSL// Temp4"] .. ".folder", item: 13));
          if @Permissions_Has(perm: "save admin") || (mistsutils.patchreporter(A: "val") == "" || skyhigh173JSON.json_has_value(json: mistsutils.patchreporter(A: "val"), value: vars["Window // UUID"])) {
            vars["Window // Save Directory"] = data.itemoflist(INDEX: 2, LIST: list("Split Text"));
            @OSL_Vars_Set(name: "save_data", data: "Success", current_command: "");
          } else {
            @Add_Popup_with_type_ontop_of(Title: "Access /" .. data.itemoflist(INDEX: 2, LIST: list("Split Text")), Subtext: "The app will gain access to files in this save", type: "save_directory", object: skyhigh173JSON.json_set(item: "directory", json: skyhigh173JSON.json_set(item: "uuid", json: skyhigh173JSON.json_set(item: "window_id", json: "{}", value: vars["WIndow // ID"]), value: vars["Window // UUID"]), value: vars["OSL// Temp4"]));
            @OSL_Vars_Set(name: "save_data", data: "Failed (Permissions)", current_command: "");
            @Window_Close(message: "No Perms");
          }
        } else {
          @Log_Error(Data: "[SDID] Invalid characters in directory name, cannot have \"/\"", Type: "Unknown");
          @OSL_Vars_Set(name: "save_data", data: "Failed (Invalid Character)", current_command: "");
        }
      } else {
        if vars["Window // Save Directory"] == "" {
          @Log_Error(Data: "[SDDU] No save directory set yet, use `save \"directory name that you want to use\" \"set_directory\"`", Type: "Unknown");
        } else {
          vars["OSL// Temp4"] = mistsutils.patchreporter(A: "`${osl.user_folder}/application data/`") .. vars["Window // Save Directory"];
          if data.itemoflist(INDEX: 2, LIST: list("Split Text")) == "contents" {
            @OSL_Vars_Set(name: "save_data", data: @parse(json: @Get_Contents_Of_Folder_Path(Path: vars["OSL// Temp4"], Show_UUIDS: null, data_included: null, Only_UUIDS: null)), current_command: "");
          } else {
            if operator.contains(STRING1: data.itemoflist(INDEX: 2, LIST: list("Split Text")), STRING2: ".") {
              vars["OSL// Temp5"] = data.itemoflist(INDEX: 2, LIST: list("Split Text"));
            } else {
              vars["OSL// Temp5"] = data.itemoflist(INDEX: 2, LIST: list("Split Text")) .. ".txt";
            }
            if data.itemoflist(INDEX: 3, LIST: list("Split Text")) == "exists" {
              @OSL_Vars_Set(name: "save_data", data: data.listcontainsitem(ITEM: vars["OSL// Temp4"] .. "/" .. vars["OSL// Temp5"], LIST: list("Files // Index Path")), current_command: "");
            } else {
              if data.itemoflist(INDEX: 3, LIST: list("Split Text")) == "set" {
                @Setup_App_Data();
                mistsutils.patchcommand2(A: "let cur = ", B: data.itemoflist(INDEX: 4, LIST: list("Split Text")));
                @Install_System_Utility(Location: vars["OSL// Temp4"], Name_And_Type: vars["OSL// Temp5"], Data: mistsutils.patchreporter(A: "typeof cur === \"object\" ? JSON.stringify(cur) : cur"), Icon: "", not_system: mistsutils.true());
              } else {
                @OSL_Vars_Set(name: "save_data", data: "", current_command: "");
                vars["Temp"] = @originFS_Path_ID(Path: vars["OSL// Temp4"] .. "/" .. vars["OSL// Temp5"]);
                if Temp > 0 {
                  if data.itemoflist(INDEX: 3, LIST: list("Split Text")) == "delete" {
                    @originFS_Exec_file_file_data_id_input(command: "immediately delete", Id: Temp, data_id: "", input: "");
                    @OSL_Vars_Set(name: "save_data", data: "Deleted", current_command: "");
                  } else {
                    mistsutils.patchcommand2(A: "const val = ", B: @File_get_item(id: Temp, item: 4));
                    if data.itemoflist(INDEX: 3, LIST: list("Split Text")) == "get" {
                      @OSL_Vars_Set(name: "save_data", data: mistsutils.patchreporter(A: "val"), current_command: "");
                    } else {
                      if data.itemoflist(INDEX: 3, LIST: list("Split Text")) == "append" {
                        @Setup_App_Data();
                        @Install_System_Utility(Location: vars["OSL// Temp4"], Name_And_Type: vars["OSL// Temp5"], Data: mistsutils.patchreporter(A: "val") .. data.itemoflist(INDEX: 4, LIST: list("Split Text")), Icon: "", not_system: mistsutils.true());
                      }
                    }
                  }
                } else {
                  @Log_Error(Data: "[SDUF] Unknown file designated in osl save command", Type: "Unknown");
                }
              }
            }
          }
        }
      }
      stop "this script";
    }
    case "loc" {
      @Go_To_Location_Of_Window(X: input2, Y: data.itemoflist(INDEX: 3, LIST: list("Split Text")), X_2: data.itemoflist(INDEX: 4, LIST: list("Split Text")), Y_2: data.itemoflist(INDEX: 5, LIST: list("Split Text")));
    }
    case "goto" {
      if @is_array(input: input2) {
        mistsutils.patchcommand(A: "spl[2] = p1[1]; p1 = p1[0]");
      }
      motion.gotoxy(X: vars["Frame // X"] + input2 * vars["Renderer // Scale"], Y: vars["Frame // Y"] + mistsutils.patchreporter(A: "spl[2]") * vars["Renderer // Scale"]);
    }
    case "change" {
      motion.gotoxy(X: motion.xposition() + input2 * vars["Renderer // Scale"], Y: motion.yposition() + data.itemoflist(INDEX: 3, LIST: list("Split Text")) * vars["Renderer // Scale"]);
    }
    case "change_x" {
      motion.changexby(DX: input2 * vars["Renderer // Scale"]);
    }
    case "change_y" {
      motion.changeyby(DY: input2 * vars["Renderer // Scale"]);
    }
    case "set_x" {
      motion.setx(X: vars["Frame // X"] + input2 * vars["Renderer // Scale"]);
    }
    case "set_y" {
      motion.sety(Y: vars["Frame // Y"] + input2 * vars["Renderer // Scale"]);
    }
    case "direction" {
      motion.pointindirection(DIRECTION: input2);
    }
    case "pointat" {
      motion.pointtowards_xyfrom(X: input2, Y: data.itemoflist(INDEX: 3, LIST: list("Split Text")), FROMX: motion.xposition() - vars["Frame // X"], FROMY: motion.yposition() - vars["Frame // Y"]);
    }
    case "turnleft" {
      motion.turnleft(DEGREES: input2);
    }
    case "turnright" {
      motion.turnright(DEGREES: input2);
    }
    case "file" {
      @OSL_Commands_Files();
      stop "this script";
    }
    case "indexedDB" {
      if @Permissions_Has(perm: "kernel") {
        switch data.itemoflist(INDEX: 2, LIST: list("Split Text")) {
          case "get" {
            @OSL_Set_Data_Var_To(data: mistiumindexeddb.readFromDatabase(KEY: data.itemoflist(INDEX: 3, LIST: list("Split Text"))));
          }
          case "set" {
            mistiumindexeddb.writeToDatabase(KEY: data.itemoflist(INDEX: 3, LIST: list("Split Text")), VALUE: data.itemoflist(INDEX: 4, LIST: list("Split Text")));
          }
          case "delete" {
            mistiumindexeddb.deleteFromDatabase(KEY: data.itemoflist(INDEX: 3, LIST: list("Split Text")));
          }
        }
        stop "this script";
      }
    }
    case "window" {
      @OSL_Commands_Window(command: input2, input2: data.itemoflist(INDEX: 3, LIST: list("Split Text")));
      stop "this script";
    }
    case "terminal" {
      if @Permissions_Has(perm: "terminal") {
        @RUSH_execute(Command: input2);
        @OSL_Vars_Set(name: "terminal_output", data: @parse(json: skyhigh173JSON.json_vm_getlist(list: skyhigh173JSON.menu_get_list(field get_list: list("*]Mn/33!d},~KykjJQ|Y")))), current_command: "");
      } else {
        @Log_Error(Data: "[TCPM] Terminal Permissions Missing", Type: "Permissions");
      }
      stop "this script";
    }
    mistsutils.patchcommand(A: "case \"return\": return {type: \"return\", value: p1 ?? null}");
    mistsutils.patchcommand(A: "case \"/@line\": return;");
    default {
      mistsutils.patchcommand3(A: "let command_obj = ", B: "target.osl_globals", C: "?.commands?.[p0]");
      if mistsutils.patchboolean(A: "typeof command_obj === \"object\"") {
        @Run_Definition(command_obj: mistsutils.patchreporter(A: "command_obj"));
      } else {
        @Log_Error(Data: mistsutils.patchreporter(A: "`Unrecognised osl token: \"${p0}\", was unable to resolve into a command or function`"), Type: "Unknown");
      }
      mistsutils.patchcommand(A: "return;");
    }
  }
  vars["OSL // Hover_Colour"] = "";
  vars["OSL // Hover_Size"] = "";
  vars["OSL // Tooltip"] = "";
}
