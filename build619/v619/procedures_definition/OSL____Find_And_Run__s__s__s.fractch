      mistsutils.patchcommand(A: "}");
      mistsutils.patchcommand2(A: "const new_x = ", B: mistsutils.patchreporter(A: "x") + input2 / 2);
      mistsutils.patchcommand2(A: "const new_y = ", B: mistsutils.patchreporter(A: "y") + mistsutils.patchreporter(A: "graph[len] * height"));
