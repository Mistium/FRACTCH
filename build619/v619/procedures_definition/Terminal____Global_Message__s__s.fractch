def @Terminal_Global_Message(Command, Window_Id("Window Id")) "Terminal // Global Message %s %s" warp=false {
  mistsutils_patchcommand(A: "let wins = origin.windows");
  if (data_listcontainsitem(ITEM: Window_Id, field LIST: list("Windows // ID", "570oYa]nLC-^Ys!KN+A~")) || mistsutils_patchreporter3(A: "wins.names.includes(", B: Window_Id, C: ")")) {
    if mistsutils_patchreporter3(A: "wins.names.includes(", B: Window_Id, C: ")") {
      @originWM_Send_global_Msg(arr: (mistsutils_patchreporter(A: "`${p0}/`") .. data_itemoflist(INDEX: mistsutils_patchreporter3(A: "wins.names.indexOf(", B: Window_Id, C: ") + 1"), field LIST: list("Windows // ID", "570oYa]nLC-^Ys!KN+A~"))));
    } else {
      @originWM_Send_global_Msg(arr: mistsutils_patchreporter(A: "`${p0}/${p1}`"));
    }
    data_addtolist(ITEM: "Force stopped the designated program", field LIST: list("Terminal", "*]Mn/33!d},~KykjJQ|Y"));
  } else {
    data_addtolist(ITEM: "There is no program open with this name", field LIST: list("Terminal", "*]Mn/33!d},~KykjJQ|Y"));
  }
}
