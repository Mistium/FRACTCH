      }
      if mistsutils_patchboolean(A: "window.osl.mouse_right") {
        vars["Right Clicked?"] = mistsutils_true();
      }
    }
  }
  pen_stamp();
  @set_stretch_to_x_y(x: mistsutils_patchreporter(A: "stretch_x"), y: mistsutils_patchreporter(A: "stretch_y"));
}
