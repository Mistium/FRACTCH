  @OSL_Vars_Set(name: "global_accent", data: mistsutils.patchreporter(A: "acc?.theme?.accent ?? \"#57cdac\""), current_command: "Global");
  @OSL_Vars_Set(name: "user_icon", data: mistsutils.patchreporter(A: "acc.pfp"), current_command: "Global");
