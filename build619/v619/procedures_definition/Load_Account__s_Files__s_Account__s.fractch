    if (not((mistiumindexeddb.readFromDatabase(KEY: "user_wallpaper_url") == mistsutils.patchreporter(A: "wallpaper.current"))) || mistsutils.patchreporter(A: "(\"\"+acc.wallpaper).endsWith(\".mp4\")")) {
