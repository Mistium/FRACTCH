  @Window_create(name: "Loader", window_data: "");
  if (sensing.keypressed(KEY_OPTION: sensing.keyoptions(field KEY_OPTION: ["t",null])) || mistsutils.patchboolean(A: "onboot.length === 0")) {
    @Window_create(name: "Terminal", window_data: "");
