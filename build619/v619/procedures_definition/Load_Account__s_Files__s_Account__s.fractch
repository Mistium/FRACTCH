  mistsutils.patchcommand(A: "let timer_load = performance.now()");
  @Timed_Log(Data: "Waiting for wallpaper");
  until ((mistSkins.getSkinLoaded(NAME: "wallpaper") && mistSkins.getSkinLoaded(NAME: "wallpaper_blur")) || (mistsutils.patchboolean(A: "performance.now() - timer_load > 3000") || mistsutils.patchboolean(A: "(\"\"+acc.wallpaper).endsWith(\".mp4\")"))) {
    wait "0";
