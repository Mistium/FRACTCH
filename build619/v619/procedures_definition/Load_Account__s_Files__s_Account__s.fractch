  mistsutils.patchcommand(A: "const encrypt = (txt, key) => cry_encrypt(txt, key, {iv: CryptoJS.enc.Utf8.parse(0)}).toString()");
  mistsutils.patchcommand(A: "const decrypt = (txt, key) => cry_decrypt(txt, key, {iv: CryptoJS.enc.Utf8.parse(0)}).toString(CryptoJS.enc.Utf8)");
  mistsutils.patchcommand(A: "origin.auth.encryptWithToken = (data) => encrypt(data, token)");
  mistsutils.patchcommand(A: "origin.auth.decryptWithToken = (data) => decrypt(data, token)");
  mistsutils.patchcommand(A: "origin.auth.getTokenValidator = () => encrypt(\"validator lmao\",\"validator\" + token)");
  mistsutils.patchcommand3(A: "origin.auth.requestRoturValidator = function*(key) { return ", B: cloudlink.fetchURL(url: mistsutils.patchreporter(A: "`https://social.rotur.dev/generate_validator?key=${encodeURIComponent(key)}&auth=${token}`")), C: "}");
