            data.addtolist(ITEM: skyhigh173JSON.json_set(item: "command", json: skyhigh173JSON.json_set(item: "source", json: vars["Server// Base Payload"], value: vars["Window // Network ID"]), value: "delete_account"), field LIST: list("Network // Outgoing Packets", "SF=codPC0bN[nV5#iX6K"));
          }
