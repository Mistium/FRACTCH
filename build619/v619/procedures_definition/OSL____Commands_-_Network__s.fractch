def @OSL_Commands_Network(input2) "OSL // Commands - Network %s" warp=true {
  switch input2 {
    case "getcache" {
      @OSL_Set_Data_Var_To(data= mistsutils_patchreporter3(A= "Object.keys(", B= vars["NETWORK // Get Web Outputs"], C= ")"));
    }
    case "get_online" {
      @OSL_Vars_Set(name= "network_data", data= @parse(json= truefantomregexp_regexp_replace_block(A= skyhigh173JSON_json_array_filter(key= "username", json= cloudlink_returnUserListData()), B= "/§\\S{10}\"/gi", C= "\"")), current_command= "");
