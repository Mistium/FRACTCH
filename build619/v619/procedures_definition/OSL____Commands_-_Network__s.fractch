      } else {
        mistsutils.patchcommand(A: "const fetches = origin.fetches.web");
        mistsutils.patchcommand2(A: "const val = ", B: data.itemoflist(INDEX: 3, field LIST: list("Split Text", ")./tR8V[bp)bg1K2.|v(")));
