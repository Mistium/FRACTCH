        mistsutils.patchcommand2(A: "const packet = ", B: skyhigh173JSON.json_set(item: "payload", json: skyhigh173JSON.json_set(item: "target", json: skyhigh173JSON.json_set(item: "source", json: skyhigh173JSON.json_delete(item: "id", json: vars["Server// Base Payload"]), value: vars["Window // Network ID"]), value: data.itemoflist(INDEX: 5, field LIST: list("Split Text", ")./tR8V[bp)bg1K2.|v("))), value: data.itemoflist(INDEX: 3, field LIST: list("Split Text", ")./tR8V[bp)bg1K2.|v("))));
