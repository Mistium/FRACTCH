        if (data.itemoflist(INDEX: 5, field LIST: list("Split Text", ")./tR8V[bp)bg1K2.|v(")) == "") {
          data.replaceitemoflist(INDEX: 5, ITEM: vars["Window // Network ID"], field LIST: list("Split Text", ")./tR8V[bp)bg1K2.|v("));
