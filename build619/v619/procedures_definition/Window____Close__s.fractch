      mistsutils.patchcommand(A: "origin.parentWindow.postMessage({ type: \"end\" }, origin.parentOrigin)");
    }
  }
  mistsutils.patchcommand(A: "const id = target.window.id");
  vars["Window // Name"] = data.itemnumoflist(ITEM: vars["WIndow // ID"], field LIST: list("Windows // ID", "570oYa]nLC-^Ys!KN+A~"));
  pointerlock.setLocked(enabled: pointerlock.menu_enabled(field enabled: ["false",null]));
  mistsutils.patchcommand2(A: "const videos = ", B: mistsutils.jsonparse(A: lmsVideo.getLoadedVideos()));
  repeat mistsutils.patchreporter(A: "videos.length") {
    mistsutils.patchcommand(A: "const vid = videos.shift()");
    if mistsutils.starts(A: mistsutils.patchreporter(A: "vid"), B: (vars["WIndow // ID"] .. "_")) {
      lmsVideo.deleteVideoURL(NAME: mistsutils.patchreporter(A: "vid"));
