                @Files_Set_ID_To_Path(ID: Id, Path: mistsutils.patchreporter3(A: "`${", B: data.itemoflist(INDEX: 3, LIST: list("Files // Current")), C: "}/${name.join(\".\").replaceAll(\"/\", \":\")}`.toLowerCase()"));
                @originFS_Exec_at_with_data_File_UUID(Command: "replace", Index: 2, Data: mistsutils.patchreporter(A: "name[0]"), Uuid: data.itemoflist(INDEX: Id, LIST: list("Files // UUIDS")));
                if data_id > 1 {
                  if data_id == 3 {
                    @originFS_Exec_at_with_data_File_UUID(Command: "move", Index: "", Data: data.itemoflist(INDEX: 3, LIST: list("Files // Current")), Uuid: data.itemoflist(INDEX: Id, LIST: list("Files // UUIDS")));
                  }
                  if data.itemoflist(INDEX: 1, LIST: list("Files // Current")) == ".folder" {
                    mistsutils.patchcommand(A: "try {");
                    mistsutils.patchcommand2(A: "let files = ", B: @Files_List_all_uuids_recursively_in(path: data.itemoflist(INDEX: @file_item_of_num(index: Id, num: 14), LIST: list("Files"))));
                    mistsutils.patchcommand3(A: "const to = ", B: data.itemoflist(INDEX: 3, LIST: list("Files // Current")) .. ("/" .. data.itemoflist(INDEX: 2, LIST: list("Files // Current"))), C: ".toLowerCase()");
                    mistsutils.patchcommand(A: "files.shift()");
                    mistsutils.patchcommand(A: "let queue = files.slice()");
                    mistsutils.patchcommand(A: "const obj = {files: queue, header: \"Moving Files\", total: queue.length, message: `Moving ${queue.length} files`, target: to}");
                    mistsutils.patchcommand(A: "origin.files.processes.push(obj)");
                    mistsutils.patchcommand(A: "} catch { }");
                  }
                }
              }
              if data_id != 10 {
                @originFS_Exec_at_with_data_File_UUID(Command: "replace", Index: 10, Data: mistsutils.patchreporter(A: "Date.now()"), Uuid: data.itemoflist(INDEX: Id, LIST: list("Files // UUIDS")));
              }
            }
            if data.itemoflist(INDEX: 1, LIST: list("Files // Current")) != ".folder" {
              @File_get_item(id: Id, item: "");
              @originFS_Exec_at_with_data_File_UUID(Command: "replace", Index: 12, Data: operator.length(STRING: list("Files // Current")), Uuid: data.itemoflist(INDEX: Id, LIST: list("Files // UUIDS")));
            }
          }
        }
        case "delete" {
