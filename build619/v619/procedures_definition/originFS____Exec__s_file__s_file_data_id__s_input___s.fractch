            mistsutils.patchcommand3(A: "let old_path = \"\"+", B: input, C: " + \"/\"");
            mistsutils.patchcommand(A: "let new_path = (old_path + name).toLowerCase()");
            mistsutils.patchcommand2(A: "old_path += ", B: data.itemoflist(INDEX: 2, LIST: list("Files // Current")));
            mistsutils.patchcommand(A: "old_path = old_path.toLowerCase()");
            mistsutils.patchcommand(A: "files.shift()");
            mistsutils.patchcommand(A: "for (let i = 0; i < files.length; i ++) {");
            @File_get_item(id: mistsutils.patchreporter(A: "files[i]"), item: "");
            mistsutils.patchcommand3(A: "if (", B: data.itemoflist(INDEX: 3, LIST: list("Files // Current")), C: ".startsWith(old_path))");
            @File_add_Data_Icon_Perms(Location: mistsutils.replace(C: mistsutils.patchreporter(A: "old_path"), A: mistsutils.patchreporter2(A: data.itemoflist(INDEX: 3, LIST: list("Files // Current")), B: ".toString().toLowerCase()"), B: mistsutils.patchreporter(A: "new_path")), Name: data.itemoflist(INDEX: 2, LIST: list("Files // Current")), Type: data.itemoflist(INDEX: 1, LIST: list("Files // Current")), Data: data.itemoflist(INDEX: 4, LIST: list("Files // Current")), Icon: data.itemoflist(INDEX: 11, LIST: list("Files // Current")), Perms: data.itemoflist(INDEX: 12, LIST: list("Files // Current")));
            mistsutils.patchcommand(A: "}");
            mistsutils.patchcommand(A: "} catch(e) { console.error(e) }");
