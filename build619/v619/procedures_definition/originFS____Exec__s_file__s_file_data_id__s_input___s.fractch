              vars["SYSTEM // Total Disk Writes"] += operator.length(STRING: input);
              @originFS_Exec_at_with_data_File_UUID(Command: "replace", Index: data_id, Data: input, Uuid: data.itemoflist(INDEX: Id, LIST: list("Files // UUIDS")));
