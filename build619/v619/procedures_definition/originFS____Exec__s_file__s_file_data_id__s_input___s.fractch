            mistsutils.patchcommand2(A: "let name = ", B: @Find_Unique_Name_For(path: input, name: data.itemoflist(INDEX: 2, LIST: list("Files // Current")) .. " copy", type: "folder"));
            mistsutils.patchcommand(A: "name = name.split(\".\"); name.pop(); name = name.join(\".\")");
            @File_add_Data_Icon_Perms(Location: input, Name: mistsutils.patchreporter(A: "name"), Type: ".folder", Data: "[]", Icon: data.itemoflist(INDEX: 11, LIST: list("Files // Current")), Perms: data.itemoflist(INDEX: 12, LIST: list("Files // Current")));
