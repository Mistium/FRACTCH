    mistsutils_patchcommand2(A: "let val = ", B: data_itemoflist(INDEX: vars["Files // Get Count"], field LIST: list("Files", "m~?pufmd(#?1E)uvMQ*-")));
    if mistsutils_patchboolean(A: "+i === 4 && val === false") {
      mistsutils_patchcommand3(A: "val = yield* window.origin.getFile(", B: data_itemoflist(INDEX: (vars["Files // Get Count"] + 10), field LIST: list("Files", "m~?pufmd(#?1E)uvMQ*-")), C: ")");
      data_replaceitemoflist(INDEX: vars["Files // Get Count"], ITEM: mistsutils_patchreporter(A: "val"), field LIST: list("Files", "m~?pufmd(#?1E)uvMQ*-"));
    }
    vars["SYSTEM // Total Disk Reads"] += 1;
    data_addtolist(ITEM: mistsutils_patchreporter(A: "val"), field LIST: list("Files // Current", "sZuM+zCt8vo`B5=)O+p."));
    mistsutils_patchcommand(A: "}");
  } else {
    mistsutils_patchcommand2(A: "const idx = ", B: mistsutils_ifthen(A: mistsutils_patchboolean(A: "typeof p1 === \"number\""), B: item, C: mistsutils_patchreporter3(A: "origin.files.entryLabels.indexOf(", B: item, C: ") + 1")));
    vars["Files // Get Count"] += mistsutils_patchreporter(A: "idx");
    mistsutils_patchcommand2(A: "let val = ", B: data_itemoflist(INDEX: vars["Files // Get Count"], field LIST: list("Files", "m~?pufmd(#?1E)uvMQ*-")));
    if mistsutils_patchboolean(A: "+idx === 4 && val === false") {
      mistsutils_patchcommand3(A: "val = yield* window.origin.getFile(", B: data_itemoflist(INDEX: (vars["Files // Get Count"] + 10), field LIST: list("Files", "m~?pufmd(#?1E)uvMQ*-")), C: ")");
      data_replaceitemoflist(INDEX: vars["Files // Get Count"], ITEM: mistsutils_patchreporter(A: "val"), field LIST: list("Files", "m~?pufmd(#?1E)uvMQ*-"));
