def @File_get_item(id, item) "File// get %s item %s" warp=true {
  if mistsutils_patchboolean(A: "typeof p0 === \"number\" || !isNaN(+p0)") {
    vars["Files // Get Count"] = id;
  } else {
    if operator_contains(STRING1: id, STRING2: "/") {
      vars["Files // Get Count"] = @originFS_Path_ID(Path: id);
    } else {
      vars["Files // Get Count"] = @originFS_UUID_ID(UUID: id);
    }
  }
  vars["Files // Get Count"] = @file_item_of_num(index: vars["Files // Get Count"], num: "0");
  if (item == "") {
    data_deletealloflist(field LIST: list("Files // Current", "sZuM+zCt8vo`B5=)O+p."));
    mistsutils_patchcommand(A: "for (let i = 1; i <= 14; i ++) {");
