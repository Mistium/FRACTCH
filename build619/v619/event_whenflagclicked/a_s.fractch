event.whenflagclicked();
vars["SYSTEM // Scroll Multiplier"] = "none";
forever {
  if mistsutils.patchreporter(A: "Date.now()") - vars["Camera // Last Accessed"] > 1000 && CameraSensingPlusSP.vidStatus() {
    CameraSensingPlusSP.turnOnCamera(field ON_OFF: "off");
    videoSensing.videoToggle(VIDEO_STATE: videoSensing.menu_VIDEO_STATE(field VIDEO_STATE: "off"));
  }
}
