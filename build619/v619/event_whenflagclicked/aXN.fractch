  }
  mistsutils.patchcommand2(A: "const len = ", B: data.lengthoflist(LIST: list("Windows // Create Names")));
  mistsutils.patchcommand(A: "for (let i = 0; i < len; i ++) {");
  vars["New Window Created?"] = "true";
  vars["Window // File ID"] = 0;
  if operator.contains(STRING1: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Names")), STRING2: "/") {
    vars["Window // File ID"] = @originFS_Path_ID(Path: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Names")));
  } else {
    if operator.length(STRING: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Names"))) == 32 {
      vars["Window // File ID"] = @originFS_UUID_ID(UUID: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Names")));
    }
  }
  if vars["Window // File ID"] == 0 {
    vars["Window // File ID"] = skyhigh173JSON.json_array_itemH(item: mistsutils.patchreporter3(A: "`${", B: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Names")), C: "}.osl`.toLowerCase()"), json: mistsutils.patchreporter3(A: "`${JSON.stringify(JSON.parse(", B: skyhigh173JSON.json_vm_getlist(list: skyhigh173JSON.menu_get_list(field get_list: list("CL33%0R^/cfdOsUUuN{9"))), C: ").join(\"\\n\").match(/(([^/]+)|\\/)$/gim))}`.toLowerCase()"));
  }
  if vars["Window // File ID"] != 0 {
    mistsutils.patchcommand(A: "origin.windows.received.unshift([])");
    mistsutils.patchcommand(A: "origin.windows.snapping.unshift(\"\")");
    vars["Window ID Count"] += 1;
    vars["WIndow // ID"] = vars["Window ID Count"];
    data.insertatlist(ITEM: vars["Window ID Count"], INDEX: 1, LIST: list("Windows // ID"));
    mistsutils.patchcommand3(A: "origin.windows.ids.unshift(", B: vars["Window ID Count"], C: ")");
    mistsutils.patchcommand2(A: "const name = ", B: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Names")));
    mistsutils.patchcommand2(A: "const passed_data = ", B: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Data")));
    mistsutils.patchcommand2(A: "const parent_ctx = ", B: data.itemoflist(INDEX: 1, LIST: list("Windows // Create Parent")));
    vars["Process // Type"] = "App";
    mistsutils.patchcommand(A: "origin.auth.token = token");
    mistsutils.patchcommand(A: "const newWin = target.makeClone();");
    mistsutils.patchcommand(A: "newWin.setup = {name, passed_data, parent_ctx}");
    mistsutils.patchcommand(A: "if (newWin) { vm.runtime.addTarget(newWin); newWin.goBehindOther(target); }");
  }
  data.deleteoflist(INDEX: 1, LIST: list("Windows // Create Data"));
  data.deleteoflist(INDEX: 1, LIST: list("Windows // Create Parent"));
  data.deleteoflist(INDEX: 1, LIST: list("Windows // Create Names"));
  mistsutils.patchcommand(A: "}");
  vars["WIndow // ID"] = -1;
  if vars["Embed Mode"] == 0 {
    mistsutils.patchcommand(A: "const processes = origin.files.processes");
    mistsutils.patchcommand(A: "for (let i = 0; i < processes.length; i ++) {");
    mistsutils.patchcommand(A: "const files = processes[i].files");
    mistsutils.patchcommand2(A: "let loops = ", B: mistsutils.clamp(A: mistsutils.patchreporter(A: "files.length"), B: 1, C: 100));
    mistsutils.patchcommand2(A: "const target = ", B: "processes[i]?.target ?? \"\"");
    switch mistsutils.patchreporter(A: "processes[i].header") {
      case "Moving Files" {
        mistsutils.patchcommand(A: "for (let _ = 0; _ < loops; _ ++) {");
        mistsutils.patchcommand(A: "const cur = files.shift()");
        mistsutils.patchcommand2(A: "const id = ", B: @originFS_UUID_ID(UUID: mistsutils.patchreporter(A: "cur")));
        @Files_Set_ID_To_Path(ID: mistsutils.patchreporter(A: "id"), Path: mistsutils.patchreporter2(A: mistsutils.patchreporter(A: "target + \"/\"") .. (@File_get_item(id: mistsutils.patchreporter(A: "id"), item: 2) .. @File_get_item(id: mistsutils.patchreporter(A: "id"), item: 1)), B: ".toLowerCase()"));
        @originFS_Exec_at_with_data_File_UUID(Command: "replace", Index: 3, Data: mistsutils.patchreporter(A: "target"), Uuid: mistsutils.patchreporter(A: "cur"));
        mistsutils.patchcommand(A: "}");
      }
      case "Deleting Files" {
        mistsutils.patchcommand(A: "let cur = \"\"; while (cur = files.shift()) {");
        data.replaceitemoflist(INDEX: @file_item_of_num(index: @originFS_UUID_ID(UUID: mistsutils.patchreporter(A: "cur")), num: 1), ITEM: ".temp", LIST: list("Files"));
        @originFS_Exec_at_with_data_File_UUID(Command: "delete", Index: "", Data: "", Uuid: mistsutils.patchreporter(A: "cur"));
        mistsutils.patchcommand(A: "}");
      }
    }
    mistsutils.patchcommand(A: "}");
    mistsutils.patchcommand(A: "for (let i = 0; i < processes.length; i ++) { if (processes[i].files.length === 0) { processes.splice(i, 1); i -- } }");
    if mistsutils.patchreporter(A: "(navigator.onLine+\"\")") == "true" {
      vars["Network // Been Online"] = "true";
      if !cloudlink.getComState() && vars["Server // User Info"] == "" {
        cloudlink.openSocket(IP: vars["Server // Current"]);
      } else {
        if vars["Server // User Info"] == "" {
          if !cloudlink.getUsernameState() {
            cloudlink.setMyName(NAME: skyhigh173JSON.json_get(item: "username", json: vars["Server// Base Payload"]));
          } else {
            if !cloudlink.getRoomState() {
              cloudlink.linkToRooms(ROOMS: vars["Server // Rooms"]);
              if cloudlink.returnMOTD() == "" {
                @Show_Notification(Icon: "network", Title: "Connected Successfully", Text: "", Style: "puck", Action: "");
              } else {
                @Show_Notification(Icon: "network", Title: cloudlink.returnMOTD(), Text: "", Style: "puck", Action: "");
              }
              cloudlink.runCMDnoID(CMD: "auth", DATA: mistsutils.patchreporter(A: "token"));
            }
          }
        }
        if cloudlink.newPacketsExist(field TYPE: "Private data") {
          @originNM_Handle_Packet_Systems();
        }
        mistsutils.patchcommand(A: "try {");
        mistsutils.patchcommand2(A: "const server = ", B: vars["Server // Name"]);
        if mistsutils.patchreporter3(A: "JSON.parse(", B: cloudlink.returnUserListData(), C: ").filter(v => v.username === server).length > 0") {
          mistsutils.patchcommand3(A: "for (let _ = 0; _ <", B: data.lengthoflist(LIST: list("Network // Outgoing Packets")), C: "; _ ++) {");
          mistsutils.patchcommand2(A: "let target_name = ", B: skyhigh173JSON.json_get(item: "target_user", json: data.itemoflist(INDEX: 1, LIST: list("Network // Outgoing Packets"))));
          if mistsutils.patchreporter(A: "target_name") == "" {
            @originNM_Send_to(data: data.itemoflist(INDEX: 1, LIST: list("Network // Outgoing Packets")), username: mistsutils.patchreporter(A: "server"));
          } else {
            @originNM_Send_to(data: data.itemoflist(INDEX: 1, LIST: list("Network // Outgoing Packets")), username: mistsutils.patchreporter(A: "target_name"));
          }
          data.deleteoflist(INDEX: 1, LIST: list("Network // Outgoing Packets"));
          mistsutils.patchcommand(A: "}");
        }
        mistsutils.patchcommand(A: "} catch {}");
      }
    } else {
      if vars["Network // Been Online"] == "true" {
        vars["Network // Been Online"] = "false";
        @Show_Notification(Icon: "network", Title: "You Are Offline", Text: "", Style: "puck", Action: "");
      }
    }
    vars["SYSTEM // Squares Clickable"] = data.lengthoflist(LIST: list("Rightclick Options")) == 0 && (vars["Files // Current Dragging"] == 0 && (vars["Windows // Any Resizing"] == 0 && (vars["Windows // Any Moving"] == 0 && vars["Can Click?"] == "true")));
    if operator.length(STRING: vars["Account// Current"]) > 0 {
      vars["OSL // Perms"] = @Root_Permissions();
      mistsutils.patchcommand(A: "const isKeyDown = origin.keyboard.isKeyDown");
      if @is_hit(key: "f2") {
        @File_add_Data_Icon_Perms(Location: mistsutils.patchreporter(A: "`${osl.user_folder}/pictures`"), Name: "Screenshot At " .. sipctime.TimestampToTime(timestamp: mistsutils.patchreporter(A: "Date.now()")), Type: ".png", Data: imgEffectsSP.stretchImg(URI: lmsLooksPlus.snapshotStage(), W: mistsutils.stagewidth() / mistsutils.stageheight() * 500, H: 500), Icon: "", Perms: "");
        @Show_Notification(Icon: "tick", Title: "New Screenshot Saved To /Pictures", Text: "", Style: "puck", Action: "");
      }
    }
  }
  if mistsutils.patchreporter3(A: "typeof ", B: vars["NETWORK // Get Web Outputs"], C: " !== \"object\"") {
    vars["NETWORK // Get Web Outputs"] = mistsutils.patchreporter(A: "{}");
  }
  mistsutils.patchcommand(A: "origin.keyboard.tabIndexes = []");
  mistsutils.patchcommand(A: "const downloads = origin.fetches.downloads");
  mistsutils.patchcommand(A: "for (let i = 0; i < downloads.length; i ++) {");
  mistsutils.patchcommand(A: "try {");
  mistsutils.patchcommand(A: "const cur = downloads[i]");
  mistsutils.patchcommand(A: "const url = cur.url");
  mistsutils.patchcommand2(A: "cur.bytes = ", B: mistfetch.getBytesById(ID: mistsutils.patchreporter(A: "url")));
  if mistfetch.isRequestCompleted(ID: mistsutils.patchreporter(A: "url")) {
    vars["Network // Download"] += mistsutils.patchreporter(A: "cur.bytes");
    mistsutils.patchcommand2(A: "let get_data = ", B: @parse(json: mistfetch.getResponseBodyById(ID: mistsutils.patchreporter(A: "url"))));
    mistsutils.patchcommand2(A: vars["NETWORK // Get Web Outputs"], B: "[url] = get_data");
    mistfetch.deleteRequestById(ID: mistsutils.patchreporter(A: "url"));
    mistsutils.patchcommand(A: "downloads.splice(i --, 1)");
  }
  mistsutils.patchcommand(A: "} catch(e) { console.error(e) }");
  mistsutils.patchcommand(A: "}");
  vars["Renderer // Total Icons"] = 0;
  vars["Renderer // Total OSL"] = 0;
  mistsutils.patchcommand(A: "} catch(e) { console.error(e)");
  @SYSTEM_Crash(message: mistsutils.patchreporter(A: "\"CRITICAL ERROR HAS OCCURRED IN KERNEL PROCESS, \" + e"), stack: mistsutils.patchreporter(A: "\"CRITICAL ERROR HAS OCCURRED IN KERNEL PROCESS\\n\\n\" + e.stack.toString()"));
  mistsutils.patchcommand(A: "}");
  mistsutils.patchcommand(A: "if (origin.windows.ids.length === 0)");
  @Window_create(name: "Terminal", window_data: "");
  mistsutils.patchcommand(A: "// requestAnimationFrame((v) => vm.runtime.sequencer.stepThreads())");
}
