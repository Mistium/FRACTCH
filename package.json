{
  "name": "fractch",
  "version": "0.7.5",
  "description": "Convert Scratch 3 .sb3 projects into a lossless, human-readable DSL and pack them back",
  "keywords": [
    "scratch",
    "sb3",
    "dsl",
    "turbowarp",
    "decompiler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mistium/FRACTCH.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "browser": "./src/browser.js",
      "default": "./src/index.js"
    },
    "./browser": "./src/browser.js",
    "./package.json": "./package.json"
  },
  "browser": "./src/browser.js",
  "bin": {
    "fractch": "./bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "echo 'No linter configured'",
    "test": "node --test test/*.test.js",
    "selftest": "node ./src/selftest.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.12",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "prettier": "^3.6.2"
  }
}
